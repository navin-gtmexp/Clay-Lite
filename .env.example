# ─────────────────────────────────────────────────────────────────────────────
# Clay-Lite Environment Variables
# Copy this file to .env and fill in the values you have.
# Only GOOGLE_CREDENTIALS_FILE is required to run the tool.
# ─────────────────────────────────────────────────────────────────────────────

# ── Apollo.io (optional — needed for "apollo" source) ────────────────────────
# Get your API key at: https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=

# ── Crunchbase (optional — needed for "crunchbase" source) ───────────────────
# Get your API key at: https://data.crunchbase.com/docs/using-the-api
CRUNCHBASE_API_KEY=

# ── BuiltWith (optional — enables higher-accuracy tech detection) ─────────────
# Get your API key at: https://api.builtwith.com/
# Without this, the free HTML scraper is used instead.
BUILTWITH_API_KEY=

# ── Google Sheets OAuth ──────────────────────────────────────────────────────
# Download an OAuth 2.0 Client ID JSON from Google Cloud Console:
#   1. Go to https://console.cloud.google.com/
#   2. Create a project → Enable "Google Sheets API" and "Google Drive API"
#   3. Go to Credentials → Create Credentials → OAuth 2.0 Client ID
#   4. Application type: Desktop app
#   5. Download the JSON and save it here
#
# Default path (gspread looks here automatically):
GOOGLE_CREDENTIALS_FILE=~/.config/gspread/credentials.json

# After your first `clay_lite run`, a token file will be saved at:
# ~/.config/gspread/authorized_user.json  (reused for all future runs)
